<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tradingmemes.healthcheck</string>

    <!-- Comando: wrapper fuera de iCloud para evitar TCC restrictions -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ulldh/tradingmemes-runner/health_check.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/ulldh/tradingmemes-runner</string>

    <!-- Ejecutar cada 6 horas -->
    <key>StartInterval</key>
    <integer>21600</integer>

    <key>StandardOutPath</key>
    <string>/Users/ulldh/tradingmemes-runner/logs/healthcheck_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ulldh/tradingmemes-runner/logs/healthcheck_stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
    </dict>

    <key>KeepAlive</key>
    <false/>

    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
