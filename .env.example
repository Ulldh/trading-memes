# ============================================================
# TRADING MEMES - Environment Variables
# ============================================================
# Copia este archivo a .env y completa los valores necesarios.
# El archivo .env NO se incluye en git (está en .gitignore).

# ============================================================
# API KEYS - Principales
# ============================================================

# Helius RPC (para holders de tokens Solana)
# Free tier: 50 calls/sec
# Obtener en: https://helius.dev
HELIUS_API_KEY=

# Etherscan API (para verificacion de contratos Ethereum)
# Free tier: 5 calls/sec
# Obtener en: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Basescan API (para verificacion de contratos Base)
# Free tier: 5 calls/sec
# Obtener en: https://basescan.org/apis
BASESCAN_API_KEY=

# CoinGecko API (opcional, para precios de mercado)
# Demo API: 10,000 calls/mes gratis
# Pro: 500,000 calls/mes ($129/mes)
# Obtener en: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Birdeye API (para OHLCV historico de tokens Solana)
# Free tier: 1 rps, sin costo
# Obtener en: https://bds.birdeye.so
BIRDEYE_API_KEY=

# X (Twitter) API v2 (opcional, para features de sentimiento social)
# Se necesita tier Basic ($100/mes) para buscar tweets recientes
# Obtener en: https://developer.x.com/en/portal/dashboard
# Usar el Bearer Token de la App (App-only authentication)
X_BEARER_TOKEN=

# ============================================================
# NOTIFICACIONES (Opcional)
# ============================================================

# Email para alertas del health monitor
# Configuracion recomendada: Gmail SMTP con App Password
# Tutorial: https://support.google.com/accounts/answer/185833
NOTIFICATION_EMAIL=

# Telegram Bot (opcional, para alertas via Telegram)
# 1. Crear bot con @BotFather: https://t.me/botfather
# 2. Obtener tu Chat ID con @userinfobot: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# SUPABASE (para almacenamiento cloud)
# ============================================================

# Backend de almacenamiento: "sqlite" (local) o "supabase" (cloud)
# Default: sqlite
# STORAGE_BACKEND=sqlite

# Supabase project URL y keys (solo si STORAGE_BACKEND=supabase)
# Obtener en: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Credenciales directas de DB (alternativa a SERVICE_ROLE_KEY)
# Si SUPABASE_DB_PASSWORD esta configurado, se usa en lugar de SERVICE_ROLE_KEY
# para la conexion psycopg2 via pooler.
SUPABASE_DB_USER=trading_app
SUPABASE_DB_PASSWORD=

# ============================================================
# CONFIGURACION AVANZADA (Opcional)
# ============================================================

# Nivel de logging
# Valores: DEBUG, INFO, WARNING, ERROR
# Default: INFO
# LOG_LEVEL=INFO

# Habilitar/deshabilitar cache de API responses
# Default: True
# CACHE_ENABLED=True

# Tiempo de vida del cache en horas
# Default: 24
# CACHE_TTL_HOURS=24

# Habilitar tracking de uso de APIs en base de datos
# Default: True
# ENABLE_API_USAGE_TRACKING=True

# ============================================================
# NOTAS
# ============================================================

# APIs sin key necesaria (funcionan sin configuracion):
# - GeckoTerminal: Rate limit 30 calls/min
# - DexScreener: Rate limit 300 calls/min

# APIs opcionales:
# - HELIUS_API_KEY: Solo necesaria si trabajas con tokens Solana
# - ETHERSCAN_API_KEY: Solo necesaria si trabajas con tokens Ethereum
# - BASESCAN_API_KEY: Solo necesaria si trabajas con tokens Base
# - COINGECKO_API_KEY: Solo necesaria si excedes 10K calls/mes

# Notificaciones:
# - NOTIFICATION_EMAIL: Para recibir alertas por email
# - TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID: Para alertas por Telegram

# Para mas informacion, ver:
# - docs/MONITORING.md (configuracion de alertas)
# - README.md (guia de inicio rapido)
